<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Printer Details" Height="400" Width="600" WindowStartupLocation="CenterOwner" ResizeMode="CanResize" WindowStyle="ToolWindow" Background="{Theme_Bg}"
        FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.8"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{Theme_BtnBg}" Padding="12" BorderBrush="{Theme_GridBorder}" BorderThickness="0,0,0,1">
            <TextBlock x:Name="lblHeaderTitle" Text="Property Listing" FontWeight="SemiBold" Foreground="{Theme_Fg}"/>
        </Border>
        <TextBox x:Name="txtPrnDetails" Grid.Row="1" IsReadOnly="True" FontFamily="Consolas" FontSize="12" VerticalScrollBarVisibility="Auto" BorderThickness="0" Margin="10" Background="Transparent" Foreground="{Theme_Fg}"/>
        <Border Grid.Row="2" Background="{Theme_BtnBg}" BorderBrush="{Theme_GridBorder}" BorderThickness="0,1,0,0" Padding="12">
            <Button x:Name="btnDetClose" Content="Close" HorizontalAlignment="Right" Width="80" Height="28" Background="{Theme_Bg}" Foreground="{Theme_Fg}" BorderBrush="{Theme_BtnBorder}" BorderThickness="1"/>
        </Border>
    </Grid>
</Window>