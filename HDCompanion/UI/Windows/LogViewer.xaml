<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lockout History" Height="600" Width="900" WindowStartupLocation="CenterOwner" ResizeMode="CanResize" WindowStyle="SingleBorderWindow" Background="{Theme_Bg}"
        FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.8"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{Theme_Bg}"/>
            <Setter Property="Foreground" Value="{Theme_SecFg}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{Theme_GridBorder}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>
    <Grid Background="{Theme_BtnBg}">
        <Grid.RowDefinitions> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/> <RowDefinition Height="Auto"/> </Grid.RowDefinitions>
        <Border Grid.Row="0" Margin="15,15,15,0" Background="{Theme_Bg}" CornerRadius="8" Padding="16" BorderBrush="{Theme_GridBorder}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/> </Grid.ColumnDefinitions>
                <Grid.RowDefinitions> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> </Grid.RowDefinitions>
                
                <Label Grid.Row="0" Grid.Column="0" Content="Operator:" Foreground="{Theme_SecFg}"/> 
                <TextBox x:Name="txtFilterOperator" Grid.Row="0" Grid.Column="1" Margin="4" Height="26" Background="{Theme_BtnBg}" Foreground="{Theme_Fg}" BorderBrush="{Theme_BtnBorder}" BorderThickness="1"/>
                
                <Label Grid.Row="0" Grid.Column="2" Content="Target User:" Foreground="{Theme_SecFg}"/> 
                <TextBox x:Name="txtFilterUser" Grid.Row="0" Grid.Column="3" Margin="4" Height="26" Background="{Theme_BtnBg}" Foreground="{Theme_Fg}" BorderBrush="{Theme_BtnBorder}" BorderThickness="1"/>
                
                <Button x:Name="btnFilter" Content="Filter Logs" Grid.Row="0" Grid.Column="4" Margin="8,4,0,4" Padding="16,0" Background="{Theme_PrimaryBg}" Foreground="{Theme_PrimaryFg}" BorderThickness="0" Height="26"/>
                
                <Label Grid.Row="1" Grid.Column="0" Content="Start Date:" Foreground="{Theme_SecFg}"/> 
                <DatePicker x:Name="dpStartDate" Grid.Row="1" Grid.Column="1" Margin="4" Height="26"/>
                
                <Label Grid.Row="1" Grid.Column="2" Content="End Date:" Foreground="{Theme_SecFg}"/> 
                <DatePicker x:Name="dpEndDate" Grid.Row="1" Grid.Column="3" Margin="4" Height="26"/>
                
                <Button x:Name="btnExport" Grid.Row="1" Grid.Column="4" Content="Export CSV" Margin="8,4,0,4" Padding="16,0" Background="{Theme_Bg}" Foreground="{Theme_Fg}" BorderBrush="{Theme_BtnBorder}" BorderThickness="1" Height="26"/>
            </Grid>
        </Border>
        
        <Border Grid.Row="1" Margin="15" Background="{Theme_Bg}" CornerRadius="8" BorderBrush="{Theme_GridBorder}" BorderThickness="1">
            <ListView x:Name="lvLogs" BorderThickness="0" Margin="8" Background="Transparent" Foreground="{Theme_Fg}" AlternationCount="2">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Height" Value="28"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{Theme_Fg}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="0" CornerRadius="4" Padding="4,0" Margin="0,1">
                                        <GridViewRowPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="true">
                                            <Setter TargetName="Bd" Property="Background" Value="{Theme_PrimaryBg}"/>
                                            <Setter Property="Foreground" Value="{Theme_PrimaryFg}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="true">
                                            <Setter TargetName="Bd" Property="Background" Value="{Theme_HoverBg}"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsSelected" Value="true"/>
                                                <Condition Property="IsMouseOver" Value="true"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="Bd" Property="Background" Value="{Theme_PrimaryBg}"/>
                                            <Setter Property="Foreground" Value="{Theme_PrimaryFg}"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter Property="Background" Value="{Theme_AltRowBg}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Timestamp" DisplayMemberBinding="{Binding Timestamp}" Width="140"/>
                        <GridViewColumn Header="Event" DisplayMemberBinding="{Binding Event}" Width="120"/>
                        <GridViewColumn Header="Target User" DisplayMemberBinding="{Binding Username}" Width="120"/>
                        <GridViewColumn Header="Details" DisplayMemberBinding="{Binding Details}" Width="250"/>
                        <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="80"/>
                        <GridViewColumn Header="Operator" DisplayMemberBinding="{Binding Operator}" Width="100"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
        
        <Border Grid.Row="2" Background="{Theme_Bg}" BorderBrush="{Theme_GridBorder}" BorderThickness="0,1,0,0" Padding="12">
            <Button x:Name="btnCloseLog" Content="Close" Width="80" Height="28" HorizontalAlignment="Right" Background="{Theme_BtnBg}" Foreground="{Theme_Fg}" BorderBrush="{Theme_BtnBorder}" BorderThickness="1"/>
        </Border>
    </Grid>
</Window>