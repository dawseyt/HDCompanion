<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pelican CU Helpdesk Companion" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource WindowBackground}"
        FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif">
    
    <Window.Resources>
        <!-- Base Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverFill}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- IconButton Style -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverFill}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Main Layout: Sidebar on Left, Content on Right -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========================================== -->
        <!-- SIDEBAR (LEFT COLUMN)                      -->
        <!-- ========================================== -->
        <Border Grid.Column="0" Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource ControlStroke}" BorderThickness="0,0,1,0" Padding="20">
            <StackPanel>
                <!-- Title & Subtitle -->
                <TextBlock x:Name="lblTitle" Text="Helpdesk Companion" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock x:Name="lblSubtitle" Text="Search less. Solve more." FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,25"/>
                
                <!-- Main Action Buttons -->
                <Button x:Name="btnRefresh" Content="Refresh List" Height="40" Background="{DynamicResource AccentFill}" Foreground="White" BorderThickness="0" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,15"/>
                
                <UniformGrid Columns="2" Rows="1" Margin="0,0,0,25">
                    <Button x:Name="btnUnlock" Content="Unlock Selected" Margin="0,0,0,0"/>
                    <Button x:Name="btnUnlockAll" Content="Unlock All" Margin="5,0,0,0"/>
                </UniformGrid>

                <!-- Search Area -->
                <TextBlock Text="Search" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>
                <TextBox x:Name="txtSearch" Height="32" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1" Margin="0,0,0,8"/>
                <TextBlock Text="Search automatically detects Users and Computers." FontSize="10" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                <Button x:Name="btnSearch" Content="Search" Height="32" Margin="0,0,0,25"/>

                <!-- Automation Area -->
                <TextBlock Text="Automation" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>
                <ComboBox x:Name="cbAutoRefresh" Height="32" VerticalContentAlignment="Center" Margin="0,0,0,15" Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextPrimary}"/>
                
                <CheckBox x:Name="chkAutoUnlock" Content="Auto-Unlock accounts" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>
                <CheckBox x:Name="chkEnableEmail" Content="Send email alerts" Foreground="{DynamicResource TextPrimary}"/>
            </StackPanel>
        </Border>

        <!-- ========================================== -->
        <!-- MAIN CONTENT (RIGHT COLUMN)                -->
        <!-- ========================================== -->
        <Grid Grid.Column="1" Background="{DynamicResource CardBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="3*"/>   <!-- ListView Area -->
                <RowDefinition Height="Auto"/> <!-- Splitter -->
                <RowDefinition Height="1*"/>   <!-- Log Area -->
            </Grid.RowDefinitions>

            <!-- Header Section -->
            <Border Grid.Row="0" Padding="20,15" BorderBrush="{DynamicResource ControlStroke}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Account List" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock x:Name="lblStatus" Text="Found 0 locked accounts. (Last Update: 00:00:00)" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="btnThemeToggle" Style="{StaticResource IconButtonStyle}" ToolTip="Toggle Theme">
                            <Path x:Name="iconTheme" Fill="{DynamicResource TextSecondary}" Stretch="Uniform" Width="16" Height="16" Data="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9c0-.46-.04-.92-.1-1.36-.98 1.37-2.58 2.26-4.4 2.26-3.03 0-5.5-2.47-5.5-5.5 0-1.82.89-3.42 2.26-4.4-.44-.06-.9-.1-1.36-.1z"/>
                        </Button>
                        <Button x:Name="btnDashboard" Style="{StaticResource IconButtonStyle}" ToolTip="Dashboard">
                            <Path Fill="{DynamicResource TextSecondary}" Stretch="Uniform" Width="16" Height="16" Data="M3 3h8v8H3zm10 0h8v8h-8zM3 13h8v8H3zm10 0h8v8h-8z"/>
                        </Button>
                        <Button x:Name="btnModifyConfig" Style="{StaticResource IconButtonStyle}" ToolTip="Settings">
                            <Path Fill="{DynamicResource TextSecondary}" Stretch="Uniform" Width="16" Height="16" Data="M19.4 13c0-.3.1-.6.1-.9s0-.6-.1-.9l2.1-1.7c.2-.2.2-.4.1-.6l-2-3.5c-.1-.2-.3-.3-.6-.2l-2.5 1c-.5-.4-1.1-.7-1.7-1l-.4-2.6c0-.2-.2-.4-.5-.4h-4c-.3 0-.5.2-.5.4l-.4 2.7c-.6.2-1.2.6-1.7 1L5 4.3c-.2-.1-.5-.1-.6.1l-2 3.5c-.1.2-.1.5.1.6L4.6 10c0 .3-.1.6-.1.9s0 .6.1.9l-2.1 1.7c-.2.2-.2.4-.1.6l2 3.5c.1.2.3.3.6.2l2.5-1c.5.4 1.1.7 1.7 1l.4 2.6c0 .2.2.4.5.4h4c.3 0 .5-.2.5-.4l.4-2.7c.6-.2 1.2-.6 1.7-1l2.5 1c.2.1.5.1.6-.1l2-3.5c.1-.2.1-.5-.1-.6l-2.1-1.6zM12 15.5c-1.9 0-3.5-1.6-3.5-3.5s1.6-3.5 3.5-3.5 3.5 1.6 3.5 3.5-1.6 3.5-3.5 3.5z"/>
                        </Button>
                        <Button x:Name="btnHelp" Style="{StaticResource IconButtonStyle}" ToolTip="Help">
                            <Path Fill="{DynamicResource TextSecondary}" Stretch="Uniform" Width="16" Height="16" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"/>
                        </Button>
                        <Button x:Name="btnTechDocs" Style="{StaticResource IconButtonStyle}" ToolTip="Documentation">
                            <Path Fill="{DynamicResource TextSecondary}" Stretch="Uniform" Width="16" Height="16" Data="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ListView Section -->
            <ListView x:Name="lvData" Grid.Row="1" Margin="10" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderThickness="0" AlternationCount="2">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Height" Value="30"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                        <Style.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter Property="Background" Value="{DynamicResource AltRowBg}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentFill}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.View>
                    <GridView x:Name="gvData"/>
                </ListView.View>
                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem x:Name="ctxViewProcesses" Header="Manage Computer"/>
                        <MenuItem x:Name="ctxPrinterMenu" Header="Printer Management"/>
                        <MenuItem x:Name="ctxUnlock" Header="Unlock Account"/>
                        <MenuItem x:Name="ctxReset" Header="Reset Password"/>
                        <MenuItem x:Name="ctxDetails" Header="View Details"/>
                        <MenuItem x:Name="ctxLockoutSource" Header="Find Lockout Source"/>
                        <MenuItem x:Name="ctxGroups" Header="Group Membership"/>
                        <MenuItem x:Name="ctxFindComputer" Header="Find User's Computer"/>
                        <MenuItem x:Name="ctxOpenFSRecord" Header="Open Freshservice Record"/>
                        <MenuItem x:Name="ctxActiveUsers" Header="Active Sessions"/>
                        <MenuItem x:Name="ctxGPResult" Header="GPResult"/>
                        <MenuItem x:Name="ctxFSInventory" Header="Freshservice Asset"/>
                        <MenuItem x:Name="ctxUptime" Header="Get Uptime"/>
                        <MenuItem x:Name="ctxPowerMenu" Header="Power Options">
                            <MenuItem x:Name="ctxRestartComputer" Header="Restart Computer"/>
                            <MenuItem x:Name="ctxShutdownComputer" Header="Shutdown Computer"/>
                        </MenuItem>
                    </ContextMenu>
                </ListView.ContextMenu>
            </ListView>

            <!-- Splitter for Resizing Log Area -->
            <GridSplitter Grid.Row="2" Height="6" HorizontalAlignment="Stretch" Background="Transparent" Cursor="SizeNS"/>

            <!-- Log Section -->
            <Border Grid.Row="3" Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource ControlStroke}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0" Margin="15,10,15,5">
                        <TextBlock Text="Event Log" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <Button x:Name="btnViewLog" Content="View Logs" HorizontalAlignment="Right" Padding="10,4" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1" Foreground="{DynamicResource TextPrimary}"/>
                    </Grid>
                    
                    <Border Grid.Row="1" Margin="15,0,15,15" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1" CornerRadius="4">
                        <RichTextBox x:Name="txtLog" Padding="8" Background="Transparent" BorderThickness="0" IsReadOnly="True" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12">
                            <FlowDocument>
                                <Paragraph Margin="0" Foreground="{DynamicResource TextSecondary}">Application Loaded. Waiting for events...</Paragraph>
                            </FlowDocument>
                        </RichTextBox>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ========================================== -->
        <!-- OVERLAYS (Z-Index Top)                     -->
        <!-- ========================================== -->
        
        <!-- Reset Password Overlay -->
        <Grid x:Name="overlayReset" Grid.ColumnSpan="2" Background="#99000000" Visibility="Collapsed">
            <Border Background="{DynamicResource CardBackground}" CornerRadius="8" BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="25" Width="450">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.4" ShadowDepth="5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock x:Name="txtPwdTitle" Text="Reset Password" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Target User:" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtResetUsername" IsReadOnly="True" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource ControlStroke}" Margin="0,0,0,15" Padding="6"/>
                    
                    <TextBlock Text="New Password:" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,15">
                        <PasswordBox x:Name="txtResetPassword" Padding="6" Foreground="{DynamicResource TextPrimary}" Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource ControlStroke}"/>
                        <TextBox x:Name="txtResetPasswordVisible" Padding="6" Visibility="Collapsed" Foreground="{DynamicResource TextPrimary}" Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource ControlStroke}"/>
                    </Grid>

                    <TextBlock Text="Confirm Password:" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,15">
                        <PasswordBox x:Name="txtConfirmPassword" Padding="6" Foreground="{DynamicResource TextPrimary}" Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource ControlStroke}"/>
                        <TextBox x:Name="txtConfirmPasswordVisible" Padding="6" Visibility="Collapsed" Foreground="{DynamicResource TextPrimary}" Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource ControlStroke}"/>
                    </Grid>
                    
                    <CheckBox x:Name="chkShowPassword" Content="Show Passwords" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <CheckBox x:Name="chkMustChange" Content="User must change password at next logon" Foreground="{DynamicResource TextPrimary}" IsChecked="True" Margin="0,0,0,15"/>
                    
                    <TextBlock x:Name="lblMatchStatus" Foreground="{DynamicResource Danger}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,15"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnGeneratePass" Content="Generate Strong" Margin="0,0,10,0" Background="{DynamicResource WindowBackground}"/>
                        <Button x:Name="btnConfirmReset" Content="Reset Password" Margin="0,0,10,0" Background="{DynamicResource AccentFill}" Foreground="White" BorderThickness="0"/>
                        <Button x:Name="btnCancelReset" Content="Cancel" Background="{DynamicResource WindowBackground}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Detailed Information Overlay -->
        <Grid x:Name="overlayDetails" Grid.ColumnSpan="2" Background="#99000000" Visibility="Collapsed">
            <Border x:Name="borderDetails" Background="{DynamicResource CardBackground}" CornerRadius="8" BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="650" Height="450">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.4" ShadowDepth="5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="{DynamicResource WindowBackground}" Padding="15" CornerRadius="8,8,0,0" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource ControlStroke}">
                        <TextBlock Text="Detailed Information" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                    </Border>
                    
                    <TextBox x:Name="txtDetailsContent" Grid.Row="1" Margin="15" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderThickness="0" FontFamily="Consolas" FontSize="13"/>
                    
                    <Border Grid.Row="2" Padding="15" Background="{DynamicResource WindowBackground}" CornerRadius="0,0,8,8" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ControlStroke}">
                        <Grid>
                            <Button x:Name="btnCloseDetails" Content="Close Window" HorizontalAlignment="Right" Padding="20,6" Background="{DynamicResource AccentFill}" Foreground="White" BorderThickness="0"/>
                            <Thumb x:Name="thumbResizeDetails" HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="12" Height="12" Cursor="SizeNWSE" Margin="0,0,-10,-10" Background="Transparent" ToolTip="Resize Window"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>